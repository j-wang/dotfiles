lsd_or_ls () {
    if command -v lsd >/dev/null 2>&1; then
        lsd $1
    else
        ls $1
    fi
}

# exa if available
alias ls=lsd_or_ls

# rstudio for issues with Java on Mac
rstudio() {
    R CMD javareconf -e
    open -a rstudio
}

# alias for reloading .zshrc easily
alias sz='source $HOME/.zshrc'

