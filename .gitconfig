[user]
	name = James Wang
	email = veriathon@gmail.com

[color]
	ui = auto
	branch = auto
	status = auto
	diff = auto
[core]
	editor = vim
	autocrlf = input
[alias]
	last = log -1 HEAD
	lg = log --oneline --decorate --all --graph -30
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[gpg]
	format = ssh

[commit]
	gpgsign = true

# Machine-specific paths (signingkey, allowedSignersFile, gpg.ssh.program)
# belong in ~/.gitconfig.local, NOT here. If signing breaks on a new
# machine, create .gitconfig.local with the local paths — do NOT add
# absolute paths back into this tracked file. See commit e47f06c.
[include]
	path = .gitconfig.local
